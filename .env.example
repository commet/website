# Objection Simulator — API key config
#
# Required for the /api/objection-simulator endpoint.
# Set these in Vercel Project → Settings → Environment Variables.
# For local dev with `vercel dev`, copy this file to .env.local and fill in.

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Optional — rate limiting (5 requests / 24h per IP).
# Create a free Redis DB at https://upstash.com and copy the REST credentials.
# If unset, the endpoint runs without rate limiting.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
